# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/carepluse

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Admin Credentials (hardcoded admin login)
ADMIN_EMAIL=admin@carepluse.com
ADMIN_PASSWORD=admin123

# Admin registration secret key (required to register as admin)
ADMIN_SECRET_KEY=carepluse_admin_secret_2024
